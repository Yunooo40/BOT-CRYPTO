{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    // NestJS relies on legacy decorators. We deliberately do NOT enable
    // emitDecoratorMetadata (esbuild can't emit it): every constructor
    // dependency is injected with an explicit @Inject(TOKEN) instead.
    "experimentalDecorators": true,
    "useDefineForClassFields": false
  },
  "include": ["src/**/*", "drizzle.config.ts"]
}
