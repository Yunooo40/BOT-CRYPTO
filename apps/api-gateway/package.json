{
  "name": "@bot/api-gateway",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "start": "node dist/main.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node dist/migrate.js",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bot/config": "workspace:*",
    "@bot/dex-adapters": "workspace:*",
    "@bot/domain": "workspace:*",
    "@bot/engine-core": "workspace:*",
    "@bot/errors": "workspace:*",
    "@bot/events": "workspace:*",
    "@bot/logger": "workspace:*",
    "@bot/observability-core": "workspace:*",
    "@bot/rpc-manager": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-ws": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "drizzle-orm": "^0.44.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jose": "^6.0.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "viem": "^2.21.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.31.0",
    "supertest": "^7.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "tsup": {
    "entry": {
      "main": "src/main.ts",
      "migrate": "src/db/migrate.ts"
    },
    "format": [
      "esm"
    ],
    "dts": false,
    "clean": true,
    "sourcemap": true
  }
}
