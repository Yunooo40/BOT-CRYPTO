{
  "name": "@bot/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "start": "node dist/main.js",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "create-wallet": "tsx scripts/create-wallet.ts"
  },
  "dependencies": {
    "@bot/config": "workspace:*",
    "@bot/dex-adapters": "workspace:*",
    "@bot/domain": "workspace:*",
    "@bot/engine-core": "workspace:*",
    "@bot/errors": "workspace:*",
    "@bot/events": "workspace:*",
    "@bot/logger": "workspace:*",
    "@bot/rpc-manager": "workspace:*",
    "@bot/scanner-core": "workspace:*",
    "@bot/shield-core": "workspace:*",
    "@bot/strategies-core": "workspace:*",
    "@bot/wallet-core": "workspace:*",
    "ioredis": "^5.4.1",
    "viem": "^2.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "tsup": {
    "entry": {
      "main": "src/main.ts"
    },
    "format": [
      "esm"
    ],
    "dts": false,
    "clean": true,
    "sourcemap": true
  }
}
