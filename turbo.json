{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "env": ["REDIS_URL", "DATABASE_URL"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@bot/dashboard#typecheck": {
      "dependsOn": ["^build", "build"]
    }
  }
}
