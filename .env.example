# Copy to .env and adjust. The app validates these at boot (fail-fast) via @bot/config.
NODE_ENV=development
LOG_LEVEL=debug

# Infra (defaults match docker-compose.yml)
DATABASE_URL=postgresql://botcrypto:botcrypto@localhost:5432/botcrypto
REDIS_URL=redis://localhost:6379

# Base RPC endpoints — comma-separated `url[|weight][|wsUrl]` entries.
# Weight (default 1) sets the share of traffic an endpoint receives.
# The public node below is rate-limited: add a dedicated provider for real use.
BASE_RPC_URLS=https://mainnet.base.org

# Passphrase maîtresse des wallets (≥ 16 caractères). Les clés privées sont
# chiffrées AES-256-GCM avec une clé dérivée (scrypt) de cette passphrase.
# Générez-la longue et aléatoire, ex.: openssl rand -base64 32
WALLET_MASTER_KEY=change-me-to-a-long-random-passphrase

# AI providers (M10) — tous optionnels ; un provider sans clé est inactif.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GROK_API_KEY=
# AI_DEFAULT_PROVIDER=anthropic

# Notifications (M11) — tous optionnels ; un canal sans config est inactif.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DISCORD_WEBHOOK_URL=
# NOTIFY_WEBHOOK_URL=
# NOTIFY_WEBHOOK_SECRET=
