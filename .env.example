# Copy to .env and adjust. The app validates these at boot (fail-fast) via @bot/config.
NODE_ENV=development
LOG_LEVEL=debug

# Infra (defaults match docker-compose.yml)
DATABASE_URL=postgresql://botcrypto:botcrypto@localhost:5432/botcrypto
REDIS_URL=redis://localhost:6379

# Base RPC endpoints — comma-separated `url[|weight][|wsUrl]` entries.
# Weight (default 1) sets the share of traffic an endpoint receives.
# The public node below is rate-limited: add a dedicated provider for real use.
BASE_RPC_URLS=https://mainnet.base.org

# API Gateway (M12)
API_PORT=3000
# HS256 secret, 32+ chars. Generate one: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-32+-char-secret
# Access-token lifetime in seconds (default 12h)
JWT_TTL_SECONDS=43200
# Bootstrap admin — upserted at gateway boot; the env is the source of truth
# for this one account (changing the password here re-hashes it).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please
# Comma-separated origins allowed by CORS (empty = same-origin only)
CORS_ORIGINS=
# Sliding-window budgets
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_LOGIN_PER_MINUTE=10

# Alerting (M14) — optional. Both must be set for fired alerts to page
# Telegram; leave unset and alerting stays log-only (no external token needed).
# TELEGRAM_BOT_TOKEN=123456:AAExampleTokenFromBotFather
# TELEGRAM_ALERT_CHAT_ID=-1001234567890

# Worker (apps/worker) — scanner + Rugpull Shield + snipe strategy + paper engine
WORKER_SNIPE_QUOTE_WEI=1000000000000000
WORKER_MAX_SLIPPAGE_BPS=500
WORKER_TICK_MS=2000
WORKER_SCAN_POLL_MS=1500
# Off by default. true = arm a demo WETH/USDC paper snipe at boot — local/demo
# runs only, never in a real deployment.
WORKER_SEED=false
# Max blocks per eth_getLogs call. Free-tier RPC providers cap this hard
# (e.g. Alchemy free tier = 10) — set to match your provider's limit or the
# scanner will fail on every poll. Default 500 assumes a paid/dedicated node.
WORKER_SCAN_MAX_BLOCK_RANGE=500
